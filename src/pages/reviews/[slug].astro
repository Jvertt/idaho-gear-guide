---
import { getCollection } from 'astro:content';
import ReviewLayout from '../../layouts/ReviewLayout.astro';
import VerdictBox from '../../components/affiliate/VerdictBox.astro';
import BuyButton from '../../components/affiliate/BuyButton.astro';
import ProductCard from '../../components/affiliate/ProductCard.astro';
import { getAffiliateLink, formatPrice, isAffiliateAvailable } from '../../utils/affiliates';
import { filterAvailableAffiliateIds } from '../../data/affiliates';
import { getProductByAffiliateId } from '../../data/products';
import { generateReviewSEO } from '../../utils/seo';
import { buildProductSchema, buildReviewSchema } from '../../utils/schema';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await review.render();

const affiliate = getAffiliateLink(review.data.affiliateId);
const product = getProductByAffiliateId(review.data.affiliateId);

if (!affiliate || !product) return;

const seo = generateReviewSEO({
  productName: affiliate.productName,
  category: review.data.category,
  affiliateId: review.data.affiliateId,
});

const productSchema = buildProductSchema({
  name: affiliate.productName,
  description: product.verdict,
  price: affiliate.price,
  rating: product.rating,
  brand: review.data.brand,
  url: seo.canonical,
});

const reviewSchema = buildReviewSchema(
  { name: affiliate.productName, price: affiliate.price, rating: product.rating, brand: review.data.brand },
  { verdict: product.verdict, datePublished: review.data.publishDate }
);

const alternativeIds = filterAvailableAffiliateIds(product.alternatives);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Reviews', url: '/gear-picks' },
  { name: affiliate.productName, url: `/reviews/${review.slug}` },
];
---

<ReviewLayout
  {...seo}
  breadcrumbs={breadcrumbs}
  jsonLd={[productSchema, reviewSchema]}
>
  {!isAffiliateAvailable(affiliate) && (
    <div class="mb-6 p-4 bg-amber/10 border border-amber/25 rounded-xl">
      <p class="font-body text-sm text-ink/85 leading-relaxed">
        We have marked this exact model as unavailable or discontinued. The write-up below is still useful for what to look for; use the alternatives or Amazon search for current SKUs.
      </p>
    </div>
  )}

  <VerdictBox affiliateId={review.data.affiliateId} score={product.rating} />

  <!-- Specs Table -->
  <div class="mb-8 overflow-x-auto">
    <h2 class="font-display text-2xl text-ink font-bold mb-4">Specifications</h2>
    <table class="w-full border-collapse">
      <tbody>
        {Object.entries(product.specs).map(([key, value], i) => (
          <tr class:list={[i % 2 === 0 ? 'bg-mist/30' : 'bg-white']}>
            <td class="font-mono text-xs text-stone uppercase tracking-wider p-3 w-1/3">{key}</td>
            <td class="font-body text-sm text-ink p-3">{value}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Pros & Cons -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-sage/5 border border-sage/20 rounded-xl p-5">
      <h3 class="font-mono text-xs text-sage uppercase tracking-wider mb-3">What We Like</h3>
      <ul class="space-y-2">
        {product.pros.map((pro) => (
          <li class="flex items-start gap-2 font-body text-sm text-ink/85">
            <span class="text-sage flex-shrink-0 mt-0.5">✓</span>
            <span>{pro}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="bg-amber/5 border border-amber/20 rounded-xl p-5">
      <h3 class="font-mono text-xs text-amber uppercase tracking-wider mb-3">What Could Be Better</h3>
      <ul class="space-y-2">
        {product.cons.map((con) => (
          <li class="flex items-start gap-2 font-body text-sm text-ink/85">
            <span class="text-amber flex-shrink-0 mt-0.5">✗</span>
            <span>{con}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Review Content -->
  <Content />

  <!-- Buy CTA -->
  <div class="mt-10 p-6 bg-cream border-2 border-amber/30 rounded-xl text-center">
    <p class="font-display text-xl text-ink font-bold mb-2">{affiliate.productName}</p>
    <p class="font-display text-2xl text-pine font-bold mb-4">{formatPrice(affiliate.price)}</p>
    <BuyButton affiliateId={review.data.affiliateId} variant="primary" />
  </div>

  <!-- Alternatives -->
  {alternativeIds.length > 0 && (
    <section class="mt-12">
      <h2 class="font-display text-2xl text-ink font-bold mb-6">Alternatives to Consider</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {alternativeIds.map((altId) => (
          <ProductCard affiliateId={altId} showSpecs={true} />
        ))}
      </div>
    </section>
  )}
</ReviewLayout>
