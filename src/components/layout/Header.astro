---
const navItems = [
  { label: 'Gear Picks', href: '/gear-picks' },
  { label: 'Explore Gear', href: '/explore-gear' },
  { label: 'Reviews', href: '/reviews/yeti-tundra-45' },
  { label: 'Guides', href: '/guides/lake-coeur-dalene-summer-outdoor-guide' },
  { label: 'About', href: '/about' },
  { label: 'Newsletter', href: '/newsletter' },
];
---

<header class="site-header sticky top-0 z-50 bg-pine border-b border-forest/50" transition:persist>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-2xl transition-transform duration-300 group-hover:scale-110">🏔️</span>
        <div>
          <span class="font-display text-lg text-cream font-bold tracking-tight group-hover:text-gold transition-colors duration-300">Idaho</span>
          <span class="font-mono text-xs text-sage block -mt-1 tracking-wider uppercase">Gear Guide</span>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="link-sweep font-body text-sm text-moss hover:text-gold transition-colors duration-300"
          >
            {item.label}
          </a>
        ))}
      </div>

      <button
        id="mobile-menu-toggle"
        class="md:hidden text-cream hover:text-gold transition-colors duration-200"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="menu-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="mobile-menu-enter md:hidden">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block py-2.5 font-body text-sm text-moss hover:text-gold transition-colors duration-200 hover:pl-1"
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');
    if (!toggle || !menu) return;

    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
      if (icon) icon.style.transform = open ? 'rotate(90deg)' : '';
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
