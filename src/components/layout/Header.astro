---
const navItems = [
  { label: 'Gear Picks', href: '/gear-picks' },
  { label: 'Reviews', href: '/reviews/yeti-tundra-45' },
  { label: 'Guides', href: '/guides/lake-coeur-dalene-summer-outdoor-guide' },
  { label: 'About', href: '/about' },
  { label: 'Newsletter', href: '/newsletter' },
];
---

<header class="bg-pine border-b border-forest/50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-2xl">🏔️</span>
        <div>
          <span class="font-display text-lg text-cream font-bold tracking-tight group-hover:text-gold transition-colors">Idaho</span>
          <span class="font-mono text-xs text-sage block -mt-1 tracking-wider uppercase">Gear Guide</span>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="font-body text-sm text-moss hover:text-gold transition-colors"
          >
            {item.label}
          </a>
        ))}
      </div>

      <button
        id="mobile-menu-toggle"
        class="md:hidden text-cream hover:text-gold transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block py-2 font-body text-sm text-moss hover:text-gold transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
