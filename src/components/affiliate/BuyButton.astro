---
import { getCloakedUrl, getAffiliateLink, formatPrice, isAffiliateAvailable, amazonSearchUrl } from '../../utils/affiliates';

export interface Props {
  affiliateId: string;
  label?: string;
  variant?: 'primary' | 'secondary' | 'compact';
  showPrice?: boolean;
}

const { affiliateId, label, variant = 'primary', showPrice = true } = Astro.props;

const affiliate = getAffiliateLink(affiliateId);
const url = getCloakedUrl(affiliateId);
const inStock = affiliate ? isAffiliateAvailable(affiliate) : false;

const defaultLabel = affiliate?.program === 'amazon' ? 'View on Amazon' : 'Check Price';

const baseClasses = 'inline-flex items-center justify-center gap-2 font-body text-sm font-semibold transition-all duration-300 rounded-lg w-full active:scale-[0.97]';

const variantClasses = {
  primary: 'bg-pine hover:bg-forest text-cream px-6 py-3',
  secondary: 'bg-forest hover:bg-sage text-cream px-5 py-2.5 border border-sage/30',
  compact: 'bg-pine hover:bg-forest text-cream px-4 py-2 text-xs',
};
---

{affiliate && inStock && (
  <div>
    <a
      href={url}
      class:list={[baseClasses, variantClasses[variant]]}
      target="_blank"
      rel="nofollow noopener sponsored"
      data-affiliate-id={affiliateId}
      onclick={`console.log('[affiliate-click] ${affiliateId}')`}
    >
      {label || defaultLabel}
      {showPrice && variant !== 'compact' && (
        <span class="opacity-70">— {formatPrice(affiliate.price)}</span>
      )}
      <svg class="w-4 h-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
      </svg>
    </a>
    <p class="text-[10px] text-stone/40 mt-2 text-center">Affiliate link — commission earned</p>
  </div>
)}
{affiliate && !inStock && (
  <div class="text-center">
    <p class="font-body text-sm text-stone mb-3">
      We no longer link to this exact SKU (discontinued or unavailable). Try similar in-stock options below or search Amazon.
    </p>
    <a
      href={amazonSearchUrl(affiliate.productName)}
      class:list={[baseClasses, variantClasses[variant]]}
      target="_blank"
      rel="nofollow noopener sponsored"
    >
      Search Amazon for similar gear
      <svg class="w-4 h-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
      </svg>
    </a>
    <p class="text-[10px] text-stone/40 mt-2">Affiliate search — commission may apply</p>
  </div>
)}
