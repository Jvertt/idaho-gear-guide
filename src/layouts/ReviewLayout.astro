---
import BaseLayout from './BaseLayout.astro';
import { buildBreadcrumbSchema } from '../utils/schema';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  twitterCard?: string;
  jsonLd?: string | string[];
  breadcrumbs: { name: string; url: string }[];
}

const { breadcrumbs, jsonLd, ...seoProps } = Astro.props;

const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs);
const allJsonLd = jsonLd
  ? Array.isArray(jsonLd)
    ? [breadcrumbSchema, ...jsonLd]
    : [breadcrumbSchema, jsonLd]
  : [breadcrumbSchema];
---

<BaseLayout {...seoProps} jsonLd={allJsonLd}>
  <slot name="head" slot="head" />
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="mb-6" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1 font-mono text-xs text-stone">
        {breadcrumbs.map((crumb, i) => (
          <li class="flex items-center gap-1">
            {i > 0 && <span class="text-sage/50">/</span>}
            {i < breadcrumbs.length - 1 ? (
              <a href={crumb.url} class="hover:text-amber transition-colors">{crumb.name}</a>
            ) : (
              <span class="text-ink/60">{crumb.name}</span>
            )}
          </li>
        ))}
      </ol>
    </nav>
    <div class="prose prose-lg max-w-none
      prose-headings:font-display prose-headings:text-ink
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:font-body prose-p:text-ink/85 prose-p:leading-relaxed
      prose-a:text-amber prose-a:no-underline hover:prose-a:text-gold
      prose-strong:text-ink prose-strong:font-semibold
      prose-li:text-ink/85 prose-li:font-body
      prose-img:rounded-xl prose-img:shadow-sm
    ">
      <slot />
    </div>
  </article>
</BaseLayout>
